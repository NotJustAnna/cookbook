---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'recipes'>['data'];

const { title, description, heroImage } = Astro.props;
---

<html lang="pt-BR">
	<head>
		<BaseHead title={`${title} — ${SITE_TITLE}`} description={description} />
		<style>
			.back {
				display: inline-block;
				margin-bottom: 2.5em;
				font-size: 0.9em;
				color: var(--ink-faint);
				text-decoration: none;
				transition: color 0.2s ease;
			}
			.back:hover {
				color: var(--accent);
			}
			.back .arrow {
				display: inline-block;
				transition: transform 0.2s ease;
				margin-right: 0.2em;
			}
			.back:hover .arrow {
				transform: translateX(-3px);
			}

			.recipe-header {
				text-align: center;
				margin-bottom: 1.5em;
			}
			.recipe-header h1 {
				font-size: 2.2em;
				margin: 0 0 0.3em;
				line-height: 1.2;
			}
			.recipe-header p {
				font-style: italic;
				color: var(--ink-light);
				margin: 0;
				font-size: 1.05em;
			}

			.hero-image {
				margin: 1.5em 0;
				text-align: center;
			}
			.hero-image img {
				max-width: 100%;
				height: auto;
				border-radius: 8px;
			}

			.ornament {
				text-align: center;
				color: var(--ink-faint);
				margin: 1.5em 0 2.5em;
				font-size: 0.85em;
				letter-spacing: 0.6em;
			}

			.prose :global(h2) {
				font-size: 1.35em;
				margin: 2.5em 0 0.8em;
				padding-bottom: 0.3em;
				border-bottom: 1px solid var(--rule);
			}
			.prose :global(h2:first-child) {
				margin-top: 0;
			}
			.prose :global(ul),
			.prose :global(ol) {
				line-height: 1.9;
			}
			.prose :global(li) {
				margin-bottom: 0.15em;
			}
			.prose :global(p) {
				margin-bottom: 1.5em;
			}

			@media (max-width: 640px) {
				.recipe-header h1 {
					font-size: 1.8em;
				}
			}
		</style>
	</head>

	<body>
		<main>
			<a href="/" class="back"><span class="arrow">&larr;</span> {SITE_TITLE}</a>
			<article>
				<div class="recipe-header">
					<h1>{title}</h1>
					<p>{description}</p>
				</div>
					{heroImage && (
						<div class="hero-image">
							<Image src={heroImage} alt={title} />
						</div>
					)}
					<div class="ornament" aria-hidden="true">&middot; &middot; &middot;</div>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
