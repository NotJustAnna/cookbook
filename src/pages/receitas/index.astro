---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const recipes = (await getCollection('recipes')).sort(
	(a, b) => a.data.title.localeCompare(b.data.title, 'pt-BR'),
);
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={`Receitas — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.filters {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-bottom: 2rem;
				justify-content: center;
			}
			.filter-btn {
				padding: 0.4em 1em;
				border: 2px solid var(--accent);
				border-radius: 999px;
				background: transparent;
				color: var(--accent);
				font-family: var(--font-atkinson);
				font-size: 0.9em;
				font-weight: 700;
				cursor: pointer;
				transition: 0.2s ease;
			}
			.filter-btn:hover,
			.filter-btn.active {
				background: var(--accent);
				color: white;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li a {
				display: block;
				padding: 1.5em;
				border-radius: 12px;
				background: white;
				box-shadow: 0 1px 4px rgba(var(--gray), 15%);
			}
			ul li a:hover {
				box-shadow: var(--box-shadow);
			}
			.category-badge {
				display: inline-block;
				padding: 0.15em 0.6em;
				background-color: var(--accent);
				color: white;
				border-radius: 999px;
				font-size: 0.7em;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				margin-bottom: 0.5em;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.2;
				font-size: 1.25em;
			}
			.description {
				margin: 0.5em 0 0;
				color: rgb(var(--gray));
				font-size: 0.9em;
				line-height: 1.4;
			}
			ul li a:hover .title {
				color: var(--accent);
			}
			@media (max-width: 720px) {
				ul {
					gap: 1em;
				}
				ul li {
					width: 100%;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="filters">
					<button class="filter-btn active" data-category="all">Todas</button>
					{CATEGORIES.map((cat) => (
						<button class="filter-btn" data-category={cat}>{cat}</button>
					))}
				</div>
				<ul>
					{
						recipes.map((recipe) => (
							<li data-category={recipe.data.category}>
								<a href={`/receitas/${recipe.id}/`}>
									<span class="category-badge">{recipe.data.category}</span>
									<h4 class="title">{recipe.data.title}</h4>
									<p class="description">{recipe.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<script>
	const buttons = document.querySelectorAll('.filter-btn');
	const items = document.querySelectorAll('ul li[data-category]');

	buttons.forEach((btn) => {
		btn.addEventListener('click', () => {
			const category = btn.getAttribute('data-category');

			buttons.forEach((b) => b.classList.remove('active'));
			btn.classList.add('active');

			items.forEach((item) => {
				if (category === 'all' || item.getAttribute('data-category') === category) {
					(item as HTMLElement).style.display = '';
				} else {
					(item as HTMLElement).style.display = 'none';
				}
			});
		});
	});
</script>
