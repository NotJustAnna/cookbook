---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const recipes = (await getCollection('recipes')).sort(
	(a, b) => a.data.title.localeCompare(b.data.title, 'pt-BR'),
);
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			@keyframes softReveal {
				from {
					opacity: 0;
					transform: translateY(6px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			.cover {
				text-align: center;
				padding: 5em 0 1em;
				animation: softReveal 0.6s ease both;
			}
			.cover h1 {
				font-family: var(--font-handwritten);
				font-size: 3.6em;
				font-weight: 400;
				color: var(--ink);
				margin: 0;
				line-height: 1.05;
			}
			.cover p {
				font-style: italic;
				color: var(--ink-light);
				margin: 0.5em 0 0;
				font-size: 1.05em;
			}

			.ornament {
				text-align: center;
				color: var(--ink-faint);
				margin: 2.2em 0;
				font-size: 0.85em;
				letter-spacing: 0.6em;
				animation: softReveal 0.6s ease 0.08s both;
			}

			.search-wrap {
				margin: 0 0 2.5em;
				animation: softReveal 0.6s ease 0.14s both;
			}
			.search-wrap input {
				width: 100%;
				padding: 0.65em 0;
				border: none;
				border-bottom: 1px solid var(--rule);
				background: transparent;
				font-family: var(--font-body);
				font-size: 1em;
				color: var(--ink);
				outline: none;
				transition: border-color 0.25s ease;
			}
			.search-wrap input::placeholder {
				color: var(--ink-faint);
				font-style: italic;
			}
			.search-wrap input:focus {
				border-bottom-color: var(--accent);
			}

			.recipes {
				list-style: none;
				margin: 0;
				padding: 0;
				animation: softReveal 0.6s ease 0.2s both;
			}
			.recipes li {
				border-bottom: 1px solid var(--rule);
			}
			.recipes li:first-child {
				border-top: 1px solid var(--rule);
			}
			.recipes li a {
				display: block;
				padding: 1.1em 0;
				text-decoration: none;
				transition: padding-left 0.25s ease;
			}
			.recipes li a:hover {
				padding-left: 0.5em;
			}
			.recipe-title {
				display: block;
				font-size: 1.15em;
				font-weight: 700;
				color: var(--ink);
				line-height: 1.3;
				transition: color 0.2s ease;
			}
			.recipe-desc {
				display: block;
				font-size: 0.88em;
				color: var(--ink-light);
				margin-top: 0.15em;
				line-height: 1.5;
			}
			.recipes li a:hover .recipe-title {
				color: var(--accent);
			}

			.count {
				text-align: center;
				color: var(--ink-faint);
				font-size: 0.85em;
				font-style: italic;
				margin-top: 2.5em;
			}
			.no-results {
				text-align: center;
				color: var(--ink-faint);
				font-style: italic;
				padding: 3em 0;
				display: none;
			}

			@media (max-width: 640px) {
				.cover {
					padding: 3.5em 0 0.5em;
				}
				.cover h1 {
					font-size: 2.8em;
				}
			}
		</style>
	</head>
	<body>
		<main>
			<div class="cover">
				<h1>{SITE_TITLE}</h1>
				<p>{SITE_DESCRIPTION}</p>
			</div>

			<div class="ornament" aria-hidden="true">&middot; &middot; &middot;</div>

			<div class="search-wrap">
				<label for="search" class="sr-only">Buscar receita</label>
				<input
					type="search"
					id="search"
					placeholder="Buscar receita\u2026"
					autocomplete="off"
				/>
			</div>

			<ul class="recipes">
				{
					recipes.map((recipe) => (
						<li
							data-title={recipe.data.title.toLowerCase()}
							data-desc={recipe.data.description.toLowerCase()}
						>
							<a href={`/receitas/${recipe.id}/`}>
								<span class="recipe-title">{recipe.data.title}</span>
								<span class="recipe-desc">{recipe.data.description}</span>
							</a>
						</li>
					))
				}
			</ul>

			<p class="no-results" id="no-results">Nenhuma receita encontrada.</p>

			<p class="count" id="count">{recipes.length} receitas</p>
		</main>
		<Footer />
	</body>
</html>

<script>
	const search = document.getElementById('search') as HTMLInputElement;
	const items = document.querySelectorAll('.recipes li');
	const noResults = document.getElementById('no-results')!;
	const count = document.getElementById('count')!;
	const total = items.length;

	function normalize(str: string): string {
		return str
			.toLowerCase()
			.normalize('NFD')
			.replace(/[\u0300-\u036f]/g, '');
	}

	search.addEventListener('input', () => {
		const q = normalize(search.value.trim());
		let visible = 0;

		items.forEach((item) => {
			const el = item as HTMLElement;
			const title = normalize(el.dataset.title || '');
			const desc = normalize(el.dataset.desc || '');
			const match = !q || title.includes(q) || desc.includes(q);
			el.style.display = match ? '' : 'none';
			if (match) visible++;
		});

		noResults.style.display = visible === 0 ? '' : 'none';
		count.textContent = q ? `${visible} de ${total} receitas` : `${total} receitas`;
	});
</script>
