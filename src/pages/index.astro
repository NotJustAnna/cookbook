---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const recipes = (await getCollection('recipes')).sort(
	(a, b) => a.data.title.localeCompare(b.data.title, 'pt-BR'),
);
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				text-align: center;
				padding: 3em 1em 2em;
			}
			.hero h1 {
				font-size: 2.5em;
				margin-bottom: 0.25em;
			}
			.hero p {
				color: rgb(var(--gray));
				font-size: 1.2em;
				margin: 0;
			}
			.categories {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;
				justify-content: center;
				margin: 2em 0 3em;
			}
			.categories a {
				padding: 0.6em 1.2em;
				border: 2px solid var(--accent);
				border-radius: 999px;
				color: var(--accent);
				font-weight: 700;
				text-decoration: none;
				transition: 0.2s ease;
			}
			.categories a:hover {
				background: var(--accent);
				color: white;
			}
			h2 {
				text-align: center;
				margin-bottom: 1.5em;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 1.5rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 0.75rem);
			}
			ul li a {
				display: block;
				padding: 1.5em;
				border-radius: 12px;
				background: white;
				box-shadow: 0 1px 4px rgba(var(--gray), 15%);
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li a:hover {
				box-shadow: var(--box-shadow);
			}
			.category-badge {
				display: inline-block;
				padding: 0.15em 0.6em;
				background-color: var(--accent);
				color: white;
				border-radius: 999px;
				font-size: 0.7em;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				margin-bottom: 0.5em;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.2;
				font-size: 1.15em;
			}
			.description {
				margin: 0.5em 0 0;
				color: rgb(var(--gray));
				font-size: 0.85em;
				line-height: 1.4;
			}
			ul li a:hover .title {
				color: var(--accent);
			}
			@media (max-width: 720px) {
				ul li {
					width: 100%;
				}
				.hero h1 {
					font-size: 2em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>{SITE_TITLE}</h1>
				<p>{SITE_DESCRIPTION}</p>
			</div>
			<nav class="categories">
				{CATEGORIES.map((cat) => (
					<a href="/receitas/">{cat}</a>
				))}
			</nav>
			<h2>Receitas</h2>
			<ul>
				{
					recipes.map((recipe) => (
						<li>
							<a href={`/receitas/${recipe.id}/`}>
								<span class="category-badge">{recipe.data.category}</span>
								<h4 class="title">{recipe.data.title}</h4>
								<p class="description">{recipe.data.description}</p>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
